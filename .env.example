# ─────────────────────────────────────────────────────────────────────────────
# Battery Decision Support Agent — Environment Variables
#
# Copy this file to .env and fill in your values.
# These env vars override anything set in config.yaml.
# For full configuration (per-agent model overrides, etc.) edit config.yaml.
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider selection ────────────────────────────────────────────────────────
# Overrides `provider:` in config.yaml
# Options: openrouter | openai | ollama
# LLM_PROVIDER=ollama

# ── OpenRouter (default — cloud) ─────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# MODEL=openai/gpt-4o             # override model without editing config.yaml

# ── OpenAI direct (alternative cloud) ────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Ollama (local — no API key required) ─────────────────────────────────────
# To use Ollama:
#   1. Install Ollama: https://ollama.com
#   2. Pull the model: ollama pull gemma4:e4b-it-q4_K_M
#   3. Start the server: ollama serve
#   4. Set provider in config.yaml:  provider: ollama
#      OR set this env var:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=gemma4:e4b-it-q4_K_M

# ── Pipeline settings ─────────────────────────────────────────────────────────
# MAX_REVISIONS=2           # max Writer revisions the Critic can trigger
# APPROVAL_THRESHOLD=7.5    # Critic score (0–10) needed to approve report
